// Optumrx clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace optumrx {

    entity Prescription {
        id: string @unique
        memberId: string
        drugId: string
        quantity: integer
        refills: integer
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Claim {
        id: string @unique
        prescriptionId: string
        pharmacyId: string
        amount: float
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Pharmacy {
        id: string @unique
        npi: string
        name: string
        network: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Drug {
        id: string @unique
        ndc: string
        name: string
        strength: string
        form: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Member {
        id: string @unique
        memberId: string
        planId: string
        groupId: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity PriorAuth {
        id: string @unique
        prescriptionId: string
        status: string
        decidedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
